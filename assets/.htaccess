# --------------------------------------------------------------
# Statische Assets: expliziter Lesezugriff
# Hilft auf Shared-Hostern, die Unterverzeichnisse per Default
# sperren (z.B. globale Deny-Regel des Anbieters).
# --------------------------------------------------------------

<IfModule mod_authz_core.c>
    Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
    Order allow,deny
    Allow from all
</IfModule>

# Korrekter MIME-Type für ES-Module (manche Hoster schicken
# JS-Module als text/plain, dann verweigert der Browser das Laden)
<IfModule mod_mime.c>
    AddType text/css                  .css
    AddType application/javascript    .js
    AddType image/svg+xml             .svg
    AddType font/woff2                .woff2
    AddType font/woff                 .woff
</IfModule>
